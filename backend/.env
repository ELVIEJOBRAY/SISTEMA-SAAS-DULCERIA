# ==========================================================
# SGDD BACKEND - VARIABLES DE ENTORNO
# ==========================================================
# ESTE ARCHIVO DEFINE TODAS LAS VARIABLES DE CONFIGURACIÓN
# DEL SISTEMA SGDD. LAS VARIABLES DE ENTORNO PERMITEN
# SEPARAR LA CONFIGURACIÓN DEL CÓDIGO FUENTE.
#
# ESTO ES UNA PRÁCTICA ESTÁNDAR EN:
# - ARQUITECTURA CLEAN
# - APLICACIONES SAAS
# - DOCKER / KUBERNETES
# - DESPLIEGUES CLOUD
#
# DE ESTA FORMA EL MISMO CÓDIGO PUEDE EJECUTARSE EN:
# - DESARROLLO
# - TESTING
# - PRODUCCIÓN
# CAMBIANDO SOLO LAS VARIABLES DE ENTORNO.


# ==========================================================
# CONFIGURACIÓN DE BASE DE DATOS
# ==========================================================
# DATABASE_URL DEFINE LA CADENA DE CONEXIÓN QUE UTILIZA
# SQLALCHEMY PARA CONECTARSE A POSTGRESQL.
#
# FORMATO GENERAL:
# postgresql://USUARIO:CONTRASEÑA@HOST:PUERTO/NOMBRE_DB
#
# COMPONENTES:
# - sgdd_usuario → usuario de la base de datos
# - sgdd_contraseña → contraseña del usuario
# - localhost → servidor donde está PostgreSQL
# - 5432 → puerto estándar de PostgreSQL
# - sgdd_bd → nombre de la base de datos
#
# EN PRODUCCIÓN ESTA URL NORMALMENTE APUNTA A:
# - AWS RDS
# - Google Cloud SQL
# - Azure PostgreSQL
DATABASE_URL=postgresql://sgdd_usuario:sgdd_contraseña@localhost:5432/sgdd_bd


# ==========================================================
# CONFIGURACIÓN DE CACHE REDIS
# ==========================================================
# REDIS ES UN SISTEMA DE ALMACENAMIENTO EN MEMORIA
# EXTREMADAMENTE RÁPIDO UTILIZADO PARA:
#
# - CACHEAR RESPUESTAS DE API
# - MANEJO DE SESIONES
# - COLAS DE TRABAJO
# - RATE LIMITING
#
# FORMATO:
# redis://HOST:PUERTO/BASE_DE_DATOS
#
# REDIS TIENE 16 BASES LÓGICAS (0-15)
# EN ESTE CASO USAMOS LA BASE 0.
REDIS_URL=redis://localhost:6379/0


# ==========================================================
# CONFIGURACIÓN DE SEGURIDAD JWT
# ==========================================================
# JWT (JSON WEB TOKEN) ES UN ESTÁNDAR UTILIZADO
# PARA AUTENTICACIÓN EN APIS MODERNAS.
#
# CUANDO UN USUARIO INICIA SESIÓN:
# 1. EL SERVIDOR GENERA UN TOKEN
# 2. EL TOKEN SE FIRMA CON JWT_SECRET
# 3. EL CLIENTE ENVÍA EL TOKEN EN CADA PETICIÓN
#
# IMPORTANTE:
# EN PRODUCCIÓN ESTE SECRET DEBE SER:
# - MUY LARGO
# - ALEATORIO
# - ALMACENADO EN UN GESTOR DE SECRETOS
JWT_SECRET=super-secret-key-change-this-in-production


# ALGORITMO UTILIZADO PARA FIRMAR LOS TOKENS.
# HS256 ES EL MÁS COMÚN PARA APIS REST.
JWT_ALGORITHM=HS256


# TIEMPO DE EXPIRACIÓN DEL TOKEN DE ACCESO
# EXPRESADO EN MINUTOS.
#
# ESTO MEJORA LA SEGURIDAD PORQUE:
# - LOS TOKENS NO DURAN PARA SIEMPRE
# - REDUCE RIESGO DE ROBO DE TOKEN
ACCESS_TOKEN_EXPIRE_MINUTES=30


# ==========================================================
# CONFIGURACIÓN DE ENTORNO
# ==========================================================
# DEFINE EL ENTORNO DE EJECUCIÓN DEL SISTEMA.
#
# POSIBLES VALORES:
# - development
# - testing
# - staging
# - production
#
# MUCHAS CONFIGURACIONES CAMBIAN SEGÚN
# EL ENTORNO (LOGS, DEBUG, SEGURIDAD).
ENVIRONMENT=development


# DEBUG ACTIVA MENSAJES DETALLADOS DE ERROR.
#
# IMPORTANTE:
# EN PRODUCCIÓN DEBE ESTAR EN FALSE
# PARA EVITAR FILTRAR INFORMACIÓN SENSIBLE.
DEBUG=True


# ==========================================================
# CONFIGURACIÓN GENERAL DE LA API
# ==========================================================
# PREFIJO GLOBAL PARA TODAS LAS RUTAS DE LA API.
#
# EJEMPLO:
# /api/v1/users
# /api/v1/auth/login
#
# ESTO PERMITE VERSIONAR LA API SIN ROMPER
# CLIENTES EXISTENTES.
API_V1_PREFIX=/api/v1


# NOMBRE DEL PROYECTO.
# UTILIZADO EN DOCUMENTACIÓN AUTOMÁTICA
# GENERADA POR FASTAPI (SWAGGER / REDOC).
PROJECT_NAME="SGDD API"


# VERSIÓN ACTUAL DE LA API.
#
# ESTO ES IMPORTANTE PARA:
# - DOCUMENTACIÓN
# - CONTROL DE CAMBIOS
# - COMPATIBILIDAD CON CLIENTES
VERSION=0.1.0