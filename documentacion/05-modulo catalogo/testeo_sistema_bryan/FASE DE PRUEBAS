# 🚀 **COMANDO PARA PRENDER/APAGAR EL SISTEMA**

Guarda esto como `sgdd.ps1` en la raíz del proyecto:

```powershell
# ============================================================
# SGDD - SISTEMA DE GESTIÓN DE DULCERÍAS
# COMANDO PARA PRENDER/APAGAR TODO EL SISTEMA
# ============================================================

param(
    [Parameter(Mandatory=$false)]
    [ValidateSet("prender", "apagar", "status", "logs", "reiniciar")]
    [string]$accion = "prender"
)

$COMPOSE_FILE = "infraestructura\docker-compose.yml"
$COMPOSE_DEV_FILE = "infraestructura\docker-compose.dev.yml"

# Colores para la consola
$verde = "Green"
$amarillo = "Yellow"
$cyan = "Cyan"
$rojo = "Red"
$blanco = "White"

function Mostrar-Banner {
    Clear-Host
    Write-Host "╔══════════════════════════════════════════════════════════════╗" -ForegroundColor $cyan
    Write-Host "║           🍬 SISTEMA-SAAS-DULCERIA v4.1.0                   ║" -ForegroundColor $cyan
    Write-Host "║        SISTEMA DE GESTIÓN PARA DULCERÍAS COLOMBIANAS        ║" -ForegroundColor $cyan
    Write-Host "╚══════════════════════════════════════════════════════════════╝" -ForegroundColor $cyan
    Write-Host ""
}

function Mostrar-Estado {
    Write-Host "📊 ESTADO DE LOS SERVICIOS:" -ForegroundColor $amarillo
    Write-Host "===========================" -ForegroundColor $amarillo
    
    docker compose -f $COMPOSE_FILE ps 2>$null
    
    Write-Host ""
    Write-Host "🌐 ACCESOS RÁPIDOS:" -ForegroundColor $verde
    Write-Host "  • Frontend: http://localhost:5173" -ForegroundColor $blanco
    Write-Host "  • Backend API: http://localhost:8000/docs" -ForegroundColor $blanco
    Write-Host "  • Health Check: http://localhost:8000/health" -ForegroundColor $blanco
    Write-Host "  • Grafana: http://localhost:3000 (admin/admin)" -ForegroundColor $blanco
    Write-Host "  • Prometheus: http://localhost:9090" -ForegroundColor $blanco
}

switch ($accion) {
    "prender" {
        Mostrar-Banner
        Write-Host "🚀 PRENDIENDO TODO EL SISTEMA..." -ForegroundColor $amarillo
        Write-Host "=================================" -ForegroundColor $amarillo
        
        # Verificar que Docker está corriendo
        docker info 2>$null | Out-Null
        if ($LASTEXITCODE -ne 0) {
            Write-Host "❌ Docker no está corriendo. Por favor inicia Docker Desktop." -ForegroundColor $rojo
            exit 1
        }
        
        # Levantar servicios principales
        Write-Host "📦 Levantando PostgreSQL y Redis..." -ForegroundColor $verde
        docker compose -f $COMPOSE_FILE up -d postgres redis
        
        Write-Host "⏳ Esperando que las bases de datos estén listas..." -ForegroundColor $amarillo
        Start-Sleep -Seconds 5
        
        # Levantar backend
        Write-Host "🚀 Levantando backend..." -ForegroundColor $verde
        docker compose -f $COMPOSE_FILE up -d backend
        
        # Levantar frontend en modo desarrollo
        Write-Host "🎨 Levantando frontend..." -ForegroundColor $verde
        docker compose -f $COMPOSE_DEV_FILE up -d frontend 2>$null
        if ($LASTEXITCODE -ne 0) {
            Write-Host "⚠️ Usando configuración alternativa para frontend..." -ForegroundColor $amarillo
            docker compose -f $COMPOSE_FILE up -d --no-deps frontend
        }
        
        # Levantar monitoreo
        Write-Host "📊 Levantando monitoreo..." -ForegroundColor $verde
        docker compose -f $COMPOSE_FILE up -d prometheus grafana
        
        Write-Host ""
        Write-Host "✅ SISTEMA PRENDIDO EXITOSAMENTE" -ForegroundColor $verde
        Write-Host ""
        
        Mostrar-Estado
        
        Write-Host ""
        Write-Host "⏳ Esperando que los servicios se estabilicen..." -ForegroundColor $amarillo
        Start-Sleep -Seconds 5
        
        # Abrir navegadores
        Write-Host "🌐 Abriendo interfaces..." -ForegroundColor $verde
        Start-Process "http://localhost:5173"
        Start-Process "http://localhost:8000/docs"
    }
    
    "apagar" {
        Mostrar-Banner
        Write-Host "🛑 APAGANDO TODO EL SISTEMA..." -ForegroundColor $amarillo
        Write-Host "==============================" -ForegroundColor $amarillo
        
        docker compose -f $COMPOSE_FILE down
        docker compose -f $COMPOSE_DEV_FILE down 2>$null
        
        Write-Host ""
        Write-Host "✅ SISTEMA APAGADO" -ForegroundColor $verde
    }
    
    "status" {
        Mostrar-Banner
        Mostrar-Estado
    }
    
    "logs" {
        Mostrar-Banner
        Write-Host "📋 MOSTRANDO LOGS EN TIEMPO REAL..." -ForegroundColor $amarillo
        Write-Host "Presiona Ctrl+C para salir" -ForegroundColor $rojo
        Write-Host ""
        docker compose -f $COMPOSE_FILE logs -f
    }
    
    "reiniciar" {
        Mostrar-Banner
        Write-Host "🔄 REINICIANDO TODO EL SISTEMA..." -ForegroundColor $amarillo
        Write-Host "================================" -ForegroundColor $amarillo
        
        docker compose -f $COMPOSE_FILE restart
        docker compose -f $COMPOSE_DEV_FILE restart frontend 2>$null
        
        Write-Host ""
        Write-Host "✅ SISTEMA REINICIADO" -ForegroundColor $verde
        Mostrar-Estado
    }
}

Write-Host ""
Write-Host "💡 Para más opciones, usa:" -ForegroundColor $cyan
Write-Host "   .\sgdd.ps1 prender   - Prende todo el sistema" -ForegroundColor $blanco
Write-Host "   .\sgdd.ps1 apagar    - Apaga todo el sistema" -ForegroundColor $blanco
Write-Host "   .\sgdd.ps1 status    - Muestra el estado de los servicios" -ForegroundColor $blanco
Write-Host "   .\sgdd.ps1 logs      - Muestra logs en tiempo real" -ForegroundColor $blanco
Write-Host "   .\sgdd.ps1 reiniciar - Reinicia todos los servicios" -ForegroundColor $blanco
```

