## 🐳 SERVICIOS DOCKER (DOCKER-COMPOSE.YML)

### Archivo `infraestructura/docker-compose.yml`

```yaml
version: '3.8'

services:
  postgres:
    image: postgres:15-alpine
    container_name: sgdd_postgres
    environment:
      POSTGRES_USER: sgdd_usuario
      POSTGRES_PASSWORD: sgdd_contraseña
      POSTGRES_DB: sgdd_bd
    ports:
      - "5432:5432"
    volumes:
      - postgres_data:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U sgdd_usuario"]
      interval: 10s
      timeout: 5s
      retries: 5
    networks:
      - sgdd_network

  redis:
    image: redis:7-alpine
    container_name: sgdd_redis
    ports:
      - "6379:6379"
    volumes:
      - redis_data:/data
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 10s
      timeout: 5s
      retries: 5
    networks:
      - sgdd_network

volumes:
  postgres_data:
  redis_data:

networks:
  sgdd_network:
    driver: bridge
```

