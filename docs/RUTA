## 🗃️ SERVICIOS IMPLEMENTADOS (56)

### 🔷 **Servicio Base** (`base_servicio.py`)
```python
from typing import Generic, TypeVar, List, Optional
from abc import ABC, abstractmethod
from app.infraestructura.repositorios.base_repositorio import RepositorioBase

T = TypeVar('T')  # Entidad
C = TypeVar('C')  # Create DTO
U = TypeVar('U')  # Update DTO
R = TypeVar('R')  # Response DTO

class ServicioBase(ABC, Generic[T, C, U, R]):
    """SERVICIO BASE CON OPERACIONES CRUD GENÉRICAS"""
    
    def __init__(self, repositorio: RepositorioBase[T]):
        self.repositorio = repositorio
    
    @abstractmethod
    def _dto_a_entidad(self, dto: C) -> T:
        """CONVIERTE DTO DE CREACIÓN A ENTIDAD DE DOMINIO"""
        pass
    
    @abstractmethod
    def _entidad_a_dto(self, entidad: T) -> R:
        """CONVIERTE ENTIDAD DE DOMINIO A DTO DE RESPUESTA"""
        pass
    
    @abstractmethod
    def _actualizar_entidad(self, entidad: T, dto: U) -> T:
        """ACTUALIZA UNA ENTIDAD EXISTENTE CON DATOS DEL DTO"""
        pass
    
    def obtener_por_id(self, id: int) -> Optional[R]:
        """CASO DE USO: OBTENER UNA ENTIDAD POR SU ID"""
        entidad = self.repositorio.obtener_por_id(id)
        return self._entidad_a_dto(entidad) if entidad else None
    
    def obtener_todos(self) -> List[R]:
        """CASO DE USO: OBTENER TODAS LAS ENTIDADES"""
        entidades = self.repositorio.obtener_todos()
        return [self._entidad_a_dto(e) for e in entidades]
    
    def crear(self, dto: C) -> R:
        """CASO DE USO: CREAR UNA NUEVA ENTIDAD"""
        entidad = self._dto_a_entidad(dto)
        entidad_guardada = self.repositorio.guardar(entidad)
        return self._entidad_a_dto(entidad_guardada)
    
    def actualizar(self, id: int, dto: U) -> Optional[R]:
        """CASO DE USO: ACTUALIZAR UNA ENTIDAD EXISTENTE"""
        entidad = self.repositorio.obtener_por_id(id)
        if not entidad:
            return None
        entidad_actualizada = self._actualizar_entidad(entidad, dto)
        entidad_guardada = self.repositorio.guardar(entidad_actualizada)
        return self._entidad_a_dto(entidad_guardada)
    
    def eliminar(self, id: int) -> bool:
        """CASO DE USO: ELIMINAR UNA ENTIDAD"""
        return self.repositorio.eliminar(id)
    
    def contar(self) -> int:
        """CASO DE USO: CONTAR EL TOTAL DE ENTIDADES"""
        return self.repositorio.contar()
```

